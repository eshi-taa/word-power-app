generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                 String   @id @default(cuid())
  email              String   @unique
  name               String?
  phone              String?  @unique
  passwordHash       String?
  firebaseUid        String?  @unique
  fcmToken           String?
  createdAt          DateTime @default(now())
  
  // Custom secure OTP tracking fields
  otp                String?
  otpExpires         DateTime?
  otpAttempts        Int      @default(0)
  otpSentAt          DateTime?
  otpSentCountHour   Int      @default(0)
  otpLastSentHourAt  DateTime?
  verified           Boolean  @default(false)
  
  progress           UserProgress[]
  quizResults        QuizResult[]
}

model Chapter {
  id        String     @id @default(cuid())
  title     String     @unique
  order     Int        @default(1)
  mainWords MainWord[]
}

model MainWord {
  id          String         @id @default(cuid())
  word        String         @unique
  meaning     String
  order       Int            @default(1)
  chapterId   String
  chapter     Chapter        @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  roots       WordRoot[]
  progress    UserProgress[]
}

model WordRoot {
  id           String        @id @default(cuid())
  name         String
  meaning      String
  mainWordId   String
  mainWord     MainWord      @relation(fields: [mainWordId], references: [id], onDelete: Cascade)
  derivedWords DerivedWord[]
}

model DerivedWord {
  id         String   @id @default(cuid())
  word       String
  definition String
  example    String?
  phonetic   String?
  audioUrl   String?
  rootId     String
  root       WordRoot @relation(fields: [rootId], references: [id], onDelete: Cascade)
}

model UserProgress {
  id             String    @id @default(cuid())
  userId         String
  mainWordId     String
  studied        Boolean   @default(false)
  studiedAt      DateTime?
  quizUnlocked   Boolean   @default(false)
  streak         Int       @default(0)
  reviewBox      Int       @default(1)
  nextReviewDate DateTime  @default(now())
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  mainWord       MainWord  @relation(fields: [mainWordId], references: [id], onDelete: Cascade)

  @@unique([userId, mainWordId])
}

model QuizResult {
  id         String   @id @default(cuid())
  userId     String
  mainWordId String
  score      Int
  passed     Boolean
  details    Json?
  takenAt    DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}
